# Mapbox access token (get one free at https://account.mapbox.com/access-tokens/)
# Can also be entered in the app under Settings.
VITE_MAPBOX_TOKEN=pk.your_token_here

# Neon Postgres connection string (server-side only — never exposed to the browser).
# The API server (server/index.mjs) uses this; the frontend talks to it via /api.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Authentication — set a strong random secret in production (signs session cookies).
AUTH_SECRET=change-me-to-a-long-random-string

# Default seeded account passwords (only used when the users table is first created).
# CHANGE THESE. Defaults are admin/admin, dispatcher/dispatcher, viewer/viewer.
# ADMIN_PASSWORD=
# DISPATCHER_PASSWORD=
# VIEWER_PASSWORD=

# Notifications (optional) — LINE Messaging API push, or a generic webhook:
# LINE_CHANNEL_TOKEN=           # LINE Messaging API channel access token
# LINE_TO=                      # LINE user/group/room id to push to
# NOTIFY_WEBHOOK_URL=           # OR a generic JSON webhook receiving { text }

# Production hardening (optional):
# NODE_ENV=production           # serves the built app + disables permissive CORS
# ALLOWED_ORIGINS=https://your-domain   # comma-separated CORS allow-list
# DISABLE_RESET=true            # fully disable the POST /api/seed reset endpoint
